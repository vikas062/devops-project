import { useRef, useEffect, useState } from "react";
import ActivityCalendar from "react-activity-calendar";
import { Card } from "./ui/card";

export const CodolioHeatmap = ({ totalSolved, activeDays, maxStreak, currentStreak }) => {
    // Generate mock data for the last year
    // In a real app, fetch /users/:username/calendar
    const generateData = () => {
        const data = [];
        const end = new Date();
        const start = new Date();
        start.setFullYear(end.getFullYear() - 1);

        for (let d = start; d <= end; d.setDate(d.getDate() + 1)) {
            // Random activity level based on activeDays per year roughly
            const isWeekend = d.getDay() === 0 || d.getDay() === 6;
            const activity = Math.random() > 0.7 ? Math.floor(Math.random() * 10) : 0;
            data.push({
                date: d.toISOString().split("T")[0],
                count: activity,
                level: activity === 0 ? 0 : activity < 3 ? 1 : activity < 6 ? 2 : activity < 9 ? 3 : 4
            });
        }
        return data;
    };

    const [data] = useState(generateData());

    return (
        <Card className="bg-[#1e1e1e] border-[#333] p-4 flex flex-col justify-between h-full">
            <div className="flex justify-between items-center mb-4">
                <h3 className="text-sm font-semibold text-slate-300">Submissions <span className="text-white ml-2">{totalSolved}</span></h3>
                <div className="flex gap-4 text-xs text-slate-400">
                    <span>Max Streak <span className="text-white font-bold">{maxStreak || 0}</span></span>
                    <span>Current Streak <span className="text-white font-bold">{currentStreak || 0}</span></span>
                    <select className="bg-[#333] border-none text-white rounded px-2 py-0.5 outline-none">
                        <option>Current Year</option>
                        <option>Last Year</option>
                    </select>
                </div>
            </div>

            <div className="flex-1 w-full overflow-x-auto min-h-[120px] flex items-center justify-center">
                <ActivityCalendar
                    data={data}
                    theme={{
                        light: ['#1e1e1e', '#0e4429', '#006d32', '#26a641', '#39d353'],
                        dark: ['#2d2d2d', '#0e4429', '#006d32', '#26a641', '#39d353'], // GitHub generic greens
                    }}
                    labels={{
                        totalCount: '{{count}} contributions in {{year}}',
                        legend: {
                            less: 'Less',
                            more: 'More',
                        },
                        months: [
                            'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
                            'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'
                        ],
                        weekdays: [
                            'Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'
                        ],
                    }}
                    fontSize={10}
                    blockSize={10}
                    blockMargin={3}
                />
            </div>
        </Card>
    );
};
