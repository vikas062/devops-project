{
  "manifest_version": 3,
  "name": "CodeCanon Solve Verifier",
  "version": "1.1.0",
  "description": "Detects accepted solves on coding platforms and syncs them to your CodeCanon dashboard.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://localhost:5173/*",
    "https://dsa-compass-server.onrender.com/*",
    "https://dsa-compass-frontend.vercel.app/*",
    "https://leetcode.com/*",
    "https://codeforces.com/*",
    "https://www.codechef.com/*",
    "https://www.geeksforgeeks.org/*",
    "https://practice.geeksforgeeks.org/*",
    "https://www.hackerrank.com/*",
    "https://atcoder.jp/*",
    "https://www.spoj.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "https://dsa-compass-frontend.vercel.app/*"
      ],
      "js": ["webapp_bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": [
        "toast.js",
        "leetcode.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://practice.geeksforgeeks.org/problems/*",
        "https://www.geeksforgeeks.org/problems/*",
        "https://www.geeksforgeeks.org/problem/*"
      ],
      "js": [
        "toast.js",
        "gfg.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.hackerrank.com/challenges/*",
        "https://www.hackerrank.com/contests/*/challenges/*",
        "https://www.hackerrank.com/domains/*"
      ],
      "js": [
        "toast.js",
        "hackerrank.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://codeforces.com/contest/*",
        "https://codeforces.com/problemset/problem/*",
        "https://codeforces.com/gym/*"
      ],
      "js": [
        "toast.js",
        "codeforces.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.codechef.com/problems/*",
        "https://www.codechef.com/*/problems/*",
        "https://www.codechef.com/practice/course/*",
        "https://www.codechef.com/submit/*"
      ],
      "js": [
        "toast.js",
        "codechef.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://atcoder.jp/contests/*"
      ],
      "js": [
        "toast.js",
        "atcoder.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.spoj.com/problems/*"
      ],
      "js": [
        "toast.js",
        "spoj.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/logo.png",
    "48": "assets/logo.png",
    "128": "assets/logo.png"
  },
  "action": {
    "default_title": "CodeCanon",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/logo.png",
      "48": "assets/logo.png",
      "128": "assets/logo.png"
    }
  }
}